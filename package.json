{
  "name": "sqd-portal-mcp",
  "version": "0.7.7",
  "description": "MCP server wrapping SQD Portal API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sqd-portal-mcp": "dist/index.js"
  },
  "scripts": {
    "build:app-ui": "node scripts/build-app-ui.mjs",
    "build": "npm run build:app-ui && tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "predev": "npm run build:app-ui",
    "dev": "tsx src/index.ts",
    "predev:http": "npm run build:app-ui",
    "dev:http": "tsx src/http.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "tsx scripts/smoke-test.ts",
    "test:tools": "tsx scripts/test-tools.ts",
    "test:routing": "tsx scripts/test-routing.ts",
    "test:substrate": "tsx scripts/test-substrate.ts",
    "test:conversations": "tsx scripts/test-conversations.ts",
    "test:negative": "tsx scripts/test-negative.ts",
    "test:quality": "tsx scripts/test-quality.ts",
    "test:all": "npm run build && npm test && npm run test:tools && npm run test:routing && npm run test:substrate && npm run test:conversations && npm run test:negative && npm run test:quality",
    "test:ci": "npm run test:all",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/hashes": "^1.8.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@cloudflare/workers-types": "^4.20250110.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
