  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(mcp_tool_calls_total, tool)",
        "hide": 0,
        "includeAll": true,
        "label": "Tool",
        "multi": true,
        "name": "tool",
        "options": [],
        "query": {
          "query": "label_values(mcp_tool_calls_total, tool)",
          "refId": "PromVarTool"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
