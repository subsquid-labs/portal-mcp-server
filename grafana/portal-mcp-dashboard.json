        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (tool) (rate(mcp_tool_calls_total{status=\"success\",tool=~\"$tool\"}[$__rate_interval]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Successful tool calls / sec",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
